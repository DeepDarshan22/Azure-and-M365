# ── Anthropic (required) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend email (required for email digest) ──────────────────────────────────
# Sign up free at https://resend.com → Create API key → paste below
RESEND_API_KEY=re_...

# The "from" address for digest emails.
# During testing you can use: onboarding@resend.dev (Resend's sandbox address)
# For production: use a verified domain in your Resend account, e.g. digest@yourdomain.com
EMAIL_FROM=onboarding@resend.dev
